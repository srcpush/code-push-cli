{
  "name": "@srcpush/code-push-cli",
  "version": "0.1.0",
  "description": "Management CLI for the CodePush service",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "start": "node ./dist/cli.js",
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "bin": {
    "srcpush": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/srcpush/code-push-cli"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "author": "Microsoft",
  "contributors": [
    "Microsoft",
    "Source Push"
  ],
  "dependencies": {
    "@inquirer/prompts": "^7.5.1",
    "chalk": "^4.1.2",
    "cli-table": "^0.3.11",
    "date-fns": "^4.1.0",
    "email-validator": "^2.0.4",
    "gradle-to-js": "2.0.1",
    "jsonwebtoken": "^9.0.2",
    "opener": "^1.5.2",
    "parse-duration": "2.1.6",
    "pathe": "^2.0.3",
    "plist": "^3.0.6",
    "progress": "^2.0.3",
    "properties": "^1.2.1",
    "recursive-fs": "2.1.0",
    "rimraf": "^6.0.1",
    "semver": "^7.7.2",
    "simctl": "^2.0.3",
    "superagent": "^10.2.1",
    "temp": "^0.9.4",
    "which": "^5.0.0",
    "wordwrap": "1.0.0",
    "xcode": "^3.0.1",
    "xml2js": "^0.6.2",
    "yargs": "^17.7.2",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitest/coverage-v8": "^3.1.4",
    "eslint": "^9.27.0",
    "express": "^4.21.2",
    "mkdirp": "^3.0.1",
    "prettier": "^3.5.3",
    "superagent-mock": "^4.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.1.4"
  }
}
